APP_ENV=dev
LOG_LEVEL=INFO
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

DATABASE_URL=postgresql+asyncpg://aibased:aibased@postgres:5432/aibased
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Authorization ---
# Single static API key. Send it as `Authorization: Bearer <API_KEY>`.
# user_id for DB ownership / rate-limit is derived deterministically from the key.
API_KEY=replace-me

# --- OpenAI ---
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WORDTOOLS_MODEL=gpt-4o-mini
LLM_CHAT_TIMEOUT_SECONDS=20
LLM_WORDTOOLS_TIMEOUT_SECONDS=8
LLM_MAX_INPUT_TOKENS=6000
LLM_MAX_OUTPUT_TOKENS=1024

# --- Chat ---
MAX_MESSAGE_CHARS=8000
HISTORY_MAX_MESSAGES=30
CHAT_SYSTEM_PROMPT=You are a helpful assistant.

# --- Word tools ---
WORD_TOOLS_PROMPTS_DIR=prompts
WORD_TOOLS_DEFAULT_LIMIT=50
WORD_TOOLS_MAX_LIMIT=200

# --- Rate limit ---
# 0 = выкл (мобильный/single-tenant backend); положительное = лимит req/min на ключ.
RATE_LIMIT_PER_MINUTE=0
RATE_LIMIT_BURST=60

# --- Music module: fal.ai ---
# Базовый URL backend'а (используется для webhook callback). В prod — https://appstorepro.store
PUBLIC_BASE_URL=
FAL_API_KEY=
FAL_BASE_URL=https://queue.fal.run
FAL_HTTP_TIMEOUT_SECONDS=30
FAL_WEBHOOK_SECRET=
FAL_MUSIC_MODEL=fal-ai/minimax-music
FAL_REFINE_MODEL=fal-ai/ace-step/audio-to-audio
FAL_SPEECH_MODEL=fal-ai/minimax/speech-02-turbo

# --- Billing webhooks ---
ADAPTY_WEBHOOK_SECRET=
RF_BILLING_WEBHOOK_SECRET=

# --- Music module: limits ---
MUSIC_MAX_CONCURRENT_GENERATIONS=8
MUSIC_VOICE_MAX_BYTES=26214400
MUSIC_VOICE_ALLOWED_CONTENT_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/x-m4a
MUSIC_VOICE_MAX_CONCURRENT_UPLOADS=4
MUSIC_DEFAULT_TRACK_DURATION_SECONDS=60
MUSIC_JOB_HARD_TIMEOUT_SECONDS=1800
