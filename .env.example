APP_ENV=dev
LOG_LEVEL=INFO
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

DATABASE_URL=postgresql+asyncpg://music:music@postgres:5432/music
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Authorization ---
API_KEY=replace-me

# --- Rate limit ---
# 0 = выкл; положительное = лимит req/min на ключ.
RATE_LIMIT_PER_MINUTE=0
RATE_LIMIT_BURST=60

# --- Music module: fal.ai ---
PUBLIC_BASE_URL=
# Для dev/смоук-тестов без реального fal: FAL_USE_STUB=true.
FAL_USE_STUB=false
FAL_API_KEY=
FAL_BASE_URL=https://queue.fal.run
FAL_HTTP_TIMEOUT_SECONDS=30
FAL_WEBHOOK_SECRET=
FAL_MUSIC_MODEL=fal-ai/minimax-music
FAL_REFINE_MODEL=fal-ai/ace-step/audio-to-audio
FAL_SPEECH_MODEL=fal-ai/minimax/speech-02-turbo

# --- Billing webhooks ---
ADAPTY_WEBHOOK_SECRET=
RF_BILLING_WEBHOOK_SECRET=

# --- Music module: limits ---
MUSIC_MAX_CONCURRENT_GENERATIONS=8
MUSIC_VOICE_MAX_BYTES=26214400
MUSIC_VOICE_ALLOWED_CONTENT_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/x-m4a
MUSIC_VOICE_MAX_CONCURRENT_UPLOADS=4
MUSIC_DEFAULT_TRACK_DURATION_SECONDS=60
MUSIC_JOB_HARD_TIMEOUT_SECONDS=1800

# --- Music module: URL validation (ТЗ §6.3) ---
# HEAD-проверка всех sample_url / voice_url перед резервом токенов.
# В dev/CI без реальных URL поставьте false.
MUSIC_URL_CHECK_ENABLED=true
MUSIC_URL_CHECK_TIMEOUT_SECONDS=3.0
