# =============================================================================
# music-backend — PRODUCTION .env (шаблон)
#
# Шаги:
#   1. cp .env.production.example .env
#   2. Заполнить значения с __REPLACE_ME__ (особенно PASSWORD, API_KEY, FAL_*,
#      ADAPTY/RF секреты).
#   3. chmod 600 .env  (чтобы только владелец читал)
#
# Для генерации новых секретов:
#   python -c "import secrets;print(secrets.token_urlsafe(32))"
# =============================================================================

APP_ENV=prod
LOG_LEVEL=INFO
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# --- Postgres (контейнер из docker-compose.prod.yml) ---
POSTGRES_USER=music
# >>> ОБЯЗАТЕЛЬНО заменить (минимум 24 случайных байта)
POSTGRES_PASSWORD=__REPLACE_ME_strong_db_password__
POSTGRES_DB=music
# DATABASE_URL формируется автоматически в docker-compose.prod.yml из 3 полей выше.
# Если запускаете миграции вне compose — можно задать явно:
# DATABASE_URL=postgresql+asyncpg://music:PASSWORD@postgres:5432/music
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Authorization ---
# Bearer-ключ для всех /v1/ запросов (кроме webhook'ов).
# Зашивается в iOS-приложении.
API_KEY=__REPLACE_ME_static_bearer_for_clients__

# --- Rate limit ---
# 0 = выкл. Включите положительное число для лимита req/min на API_KEY.
RATE_LIMIT_PER_MINUTE=0
RATE_LIMIT_BURST=60

# --- Public base URL ---
# https://<ваш домен> — обязательно для fal webhook callback.
PUBLIC_BASE_URL=https://appsprobek.shop

# --- fal.ai ---
# В прод оставьте FAL_USE_STUB=false.
FAL_USE_STUB=false
# >>> Ключ из личного кабинета fal.ai (https://fal.ai/dashboard/keys)
FAL_API_KEY=__REPLACE_ME_fal_api_key__
FAL_BASE_URL=https://queue.fal.run
FAL_HTTP_TIMEOUT_SECONDS=30
# Секрет для подписи входящих webhook'ов от fal (HMAC-SHA256 в X-Fal-Signature).
# Этот же секрет указывается при настройке webhook в fal.ai.
FAL_WEBHOOK_SECRET=__REPLACE_ME_fal_webhook_hmac_secret__
FAL_MUSIC_MODEL=fal-ai/minimax-music
FAL_REFINE_MODEL=fal-ai/ace-step/audio-to-audio
FAL_SPEECH_MODEL=fal-ai/minimax/speech-02-turbo

# --- Adapty (App Store / Google Play подписки) ---
# Bearer-секрет для webhook'ов Adapty (header Authorization).
# Задаётся в Adapty Dashboard → Integrations → Webhook → Authorization.
ADAPTY_WEBHOOK_SECRET=__REPLACE_ME_adapty_bearer_secret__

# --- RuStore  ---
# HMAC-SHA256 секрет для webhook'ов (X-RuStore-Signature).
RF_BILLING_WEBHOOK_SECRET=__REPLACE_ME_rustore_hmac_secret__

# --- Music module: limits ---
MUSIC_MAX_CONCURRENT_GENERATIONS=8
MUSIC_VOICE_MAX_BYTES=26214400
MUSIC_VOICE_ALLOWED_CONTENT_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/x-m4a
MUSIC_VOICE_MAX_CONCURRENT_UPLOADS=4
MUSIC_DEFAULT_TRACK_DURATION_SECONDS=60
MUSIC_JOB_HARD_TIMEOUT_SECONDS=1800

# --- URL validation ---
# В prod включаем HEAD-проверку URL'ов перед резервом токенов.
MUSIC_URL_CHECK_ENABLED=true
MUSIC_URL_CHECK_TIMEOUT_SECONDS=3.0
