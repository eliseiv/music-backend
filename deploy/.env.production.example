# Этот файл — шаблон для /opt/aibased/.env на сервере.
# Скопируйте его как .env и заполните значения.

APP_ENV=prod
LOG_LEVEL=INFO

# DATABASE_URL формируется в docker-compose.prod.yml автоматически
# из POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB. Здесь его НЕ дублируйте.
POSTGRES_USER=aibased
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_СИЛЬНЫЙ_ПАРОЛЬ
POSTGRES_DB=aibased
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Образ из ghcr.io подставится автоматически из CI (.env.image).
# Здесь оставьте placeholder — compose объединит оба файла.
API_IMAGE=ghcr.io/your-org/your-repo:latest

# --- Authorization ---
API_KEY=ЗАМЕНИТЕ_НА_СИЛЬНЫЙ_СЕКРЕТ_ДЛЯ_iOS_КЛИЕНТА

# --- OpenAI ---
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WORDTOOLS_MODEL=gpt-4o-mini
LLM_CHAT_TIMEOUT_SECONDS=20
LLM_WORDTOOLS_TIMEOUT_SECONDS=8
LLM_MAX_INPUT_TOKENS=6000
LLM_MAX_OUTPUT_TOKENS=1024

# --- Chat ---
MAX_MESSAGE_CHARS=8000
HISTORY_MAX_MESSAGES=30
CHAT_SYSTEM_PROMPT=You are a helpful assistant.

# --- Word tools ---
WORD_TOOLS_PROMPTS_DIR=prompts
WORD_TOOLS_DEFAULT_LIMIT=50
WORD_TOOLS_MAX_LIMIT=200

# --- Rate limit ---
# 0 = выкл (для iOS-сценария). Если включаете лимит — ставьте 60+.
RATE_LIMIT_PER_MINUTE=0
RATE_LIMIT_BURST=60
